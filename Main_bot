import os
import asyncio
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from typing import List, Optional
from database import get_db

app = FastAPI(title="Bot Manager API")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

db = get_db()

# BƯỚC 1: CẬP NHẬT KHUÔN DỮ LIỆU ĐỂ KHỚP VỚI CODE CỦA BẠN
class BotConfig(BaseModel):
    name: str
    bot_type: str # Ví dụ: 'news_agent', 'reply_bot', hoặc 'combo'
    user_token: str
    groq_key: str
    channel_id: Optional[int] = None
    guild_id: Optional[int] = None
    rss_urls: List[str] = []
    keywords: List[str] = []
    dataset_path: Optional[str] = None
    allowed_guilds: List[int] = []
    allowed_channels: List[int] = []

# BƯỚC 2: HÀM SINH CODE TỰ ĐỘNG (CODE GENERATOR)
def generate_runner_script(bot_id: str, config: BotConfig):
    """Hàm này tạo ra file Python vật lý dựa trên config"""
    
    # Đảm bảo thư mục tồn tại
    os.makedirs("../generated_bots", exist_ok=True)
    file_path = f"../generated_bots/runner_{bot_id}.py"

    # Xây dựng nội dung file code bằng f-string
    script_content = """import asyncio\nfrom news_bot import DiscordAgent\nfrom reply_bot import ReplyBot\n\n"""
    
    start_tasks = []

    # Nếu cấu hình yêu cầu chạy News Agent
    if config.bot_type in ['news_agent', 'combo']:
        script_content += f"""agent = DiscordAgent(
    user_token="{config.user_token}",
    groq_key="{config.groq_key}",
    channel_id={config.channel_id},
    guild_id={config.guild_id},
    rss_urls={config.rss_urls},
    keywords={config.keywords}
)\n\n"""
        start_tasks.append("agent.start(agent.user_token)")

    # Nếu cấu hình yêu cầu chạy Reply Bot
    if config.bot_type in ['reply_bot', 'combo']:
        script_content += f"""bot = ReplyBot(
    user_token="{config.user_token}",
    groq_key="{config.groq_key}",
    dataset_path="{config.dataset_path or 'data.txt'}",
    allowed_guilds={config.allowed_guilds},
    allowed_channels={config.allowed_channels},
    keywords={config.keywords}
)\n\n"""
        start_tasks.append("bot.start(bot.user_token)")

    # Gom các task vào asyncio.gather
    tasks_str = ",\n        ".join(start_tasks)
    
    script_content += f"""async def main():
    await asyncio.gather(
        {tasks_str}
    )

asyncio.run(main())
"""

    # Ghi ra file
    with open(file_path, "w", encoding="utf-8") as f:
        f.write(script_content)
        
    return file_path


# BƯỚC 3: CẬP NHẬT API ENDPOINT
@app.post("/bots")
def create_bot(bot: BotConfig):
    # 1. Lưu cấu hình vào Supabase
    new_bot_data = bot.model_dump()
    new_bot_data["status"] = "stopped"
    
    response = db.table("bots").insert(new_bot_data).execute()
    created_data = response.data[0]
    bot_id = created_data['id']
    
    # 2. Gọi hàm sinh file code
    script_path = generate_runner_script(str(bot_id), bot)
    
    return {
        "status": "success", 
        "message": "Đã lưu cấu hình và sinh code thành công!", 
        "script_path": script_path,
        "data": created_data
    }